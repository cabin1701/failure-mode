---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export async function getStaticPaths() {
  const specimens = await getCollection('failureMood');
  return specimens.map((spec) => ({
    params: { slug: spec.id },
    props: { spec, all: specimens },
  }));
}

const { spec, all } = Astro.props;
const { Content } = await render(spec);
const base = import.meta.env.BASE_URL;

const fmtDate = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;

const fmtDateTimeJST = (d: Date) => {
  const parts = new Intl.DateTimeFormat('en-CA', {
    timeZone: 'Asia/Tokyo',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
  }).formatToParts(d);
  const get = (t: string) => parts.find((p) => p.type === t)?.value ?? '';
  return `${get('year')}-${get('month')}-${get('day')} ${get('hour')}:${get('minute')} JST`;
};

// Archive months for sidebar
const currentYm = `${spec.data.date.getFullYear()}-${String(spec.data.date.getMonth() + 1).padStart(2, '0')}`;
const monthsMap = new Map<string, number>();
for (const s of all) {
  const k = `${s.data.date.getFullYear()}-${String(s.data.date.getMonth() + 1).padStart(2, '0')}`;
  monthsMap.set(k, (monthsMap.get(k) || 0) + 1);
}
const months = Array.from(monthsMap.entries())
  .sort((a, b) => (a[0] < b[0] ? 1 : -1))
  .map(([k, count]) => {
    const [y, m] = k.split('-');
    const name = new Date(Number(y), Number(m) - 1, 1).toLocaleString('en-US', { month: 'long' });
    return { ym: k, label: `${name} ${y}`, count, isCurrent: k === currentYm };
  });
---

<Layout title={`${spec.data.title} — Failure Mood`} lang="en">
  <Header lang="en" />

  <div class="specimen-shell">
    <article class="specimen">
      <p class="specimen-breadcrumb">
        <a href={base}>← Back to Failure Mood</a>
      </p>

      <header class="specimen-header">
        <h1 class="specimen-title">{spec.data.title}</h1>
        <p class="specimen-meta">
          <time datetime={spec.data.date.toISOString()}>{fmtDateTimeJST(spec.data.date)}</time>
          <span class="sep">•</span>
          <a class="meta-link" href={`${base}crew/${spec.data.crew.toLowerCase()}/`}>AI {spec.data.crew}</a>
          <span class="sep">•</span>
          <a class="meta-link" href={`${base}model/${spec.data.model.toLowerCase().replace(/[\s.]+/g, '-')}/`}>{spec.data.model}</a>
        </p>
        {spec.data.context && <p class="specimen-context">{spec.data.context}</p>}
      </header>

      <div class="specimen-body">
        <Content />
      </div>
    </article>

    <aside class="specimen-sidebar" aria-label="Archives">
      <h2 class="sidebar-title">Archives</h2>
      <ul class="sidebar-list">
        {months.map((m) => (
          <li class:list={['sidebar-item', { 'is-current': m.isCurrent }]}>
            <a href={`${base}archive/${m.ym}/`} class="sidebar-link">
              <span class="sidebar-label">{m.label}</span>
              <span class="sidebar-count">({m.count})</span>
            </a>
          </li>
        ))}
      </ul>
    </aside>
  </div>

  <Footer />
</Layout>

<style>
  .specimen-shell {
    max-width: 1100px;
    margin: 2.5rem auto 4rem;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 3rem;
  }
  .specimen {
    min-width: 0;
  }
  .specimen-sidebar {
    position: sticky;
    top: 2rem;
    align-self: start;
  }
  .sidebar-title {
    font-family: var(--font-heading);
    color: var(--color-tagline);
    font-size: 1.1rem;
    margin: 0 0 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .sidebar-item {
    font-family: 'Lora', serif;
    font-size: 0.95rem;
  }
  .sidebar-link {
    color: var(--color-text);
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.25rem 0;
  }
  .sidebar-link:hover .sidebar-label {
    color: var(--color-primary);
    text-decoration: underline;
  }
  .sidebar-item.is-current .sidebar-label {
    color: var(--color-primary);
    font-weight: 600;
  }
  .sidebar-count {
    font-family: 'Lora', serif;
    font-size: 0.8rem;
    opacity: 0.6;
    margin-left: 0.5rem;
  }
  @media (max-width: 768px) {
    .specimen-shell {
      grid-template-columns: 1fr;
    }
    .specimen-sidebar {
      position: static;
      border-top: 1px solid rgba(0, 0, 0, 0.1);
      padding-top: 1.5rem;
    }
  }
  .specimen-breadcrumb {
    margin: 0 0 1.5rem;
    font-family: 'Lora', serif;
    font-size: 0.95rem;
  }
  .specimen-breadcrumb a {
    color: var(--color-primary);
    text-decoration: none;
  }
  .specimen-breadcrumb a:hover {
    text-decoration: underline;
  }
  .specimen-header {
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
  }
  .specimen-title {
    font-family: var(--font-heading);
    color: var(--color-primary);
    font-size: 1.9rem;
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }
  .specimen-meta {
    margin: 0 0 1rem;
    font-family: 'Lora', serif;
    font-size: 0.95rem;
    color: var(--color-text);
    opacity: 0.8;
  }
  .specimen-meta .sep {
    margin: 0 0.5rem;
    opacity: 0.5;
  }
  .specimen-meta .meta-link {
    color: var(--color-primary);
    text-decoration: none;
  }
  .specimen-meta .meta-link:hover { text-decoration: underline; }
  .specimen-context {
    margin: 0;
    font-family: 'Lora', serif;
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-text);
    opacity: 0.75;
    line-height: 1.6;
  }
  .specimen-body :global(h1),
  .specimen-body :global(h2),
  .specimen-body :global(h3) {
    font-family: var(--font-heading);
    color: var(--color-text);
    margin-top: 2rem;
  }
  .specimen-body :global(h1) {
    font-size: 1.4rem;
  }
  .specimen-body :global(p) {
    line-height: 1.8;
    margin: 0 0 1.1rem;
  }
  .specimen-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.12);
    margin: 2rem 0;
  }
  .specimen-body :global(em) {
    color: var(--color-text);
    opacity: 0.65;
  }
  .specimen-body :global(strong) {
    color: var(--color-primary);
  }
  .specimen-body :global(table) {
    border-collapse: collapse;
    margin: 1.5rem 0;
    width: 100%;
    font-size: 0.95rem;
  }
  .specimen-body :global(th),
  .specimen-body :global(td) {
    border: 1px solid rgba(0, 0, 0, 0.18);
    padding: 0.55rem 0.85rem;
    text-align: left;
    vertical-align: top;
  }
  .specimen-body :global(th) {
    background: rgba(0, 0, 0, 0.04);
    font-weight: 600;
    font-family: var(--font-heading);
    color: var(--color-primary);
  }
  .specimen-body :global(tr:nth-child(even) td) {
    background: rgba(0, 0, 0, 0.02);
  }
</style>
